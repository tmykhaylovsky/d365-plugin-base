<Application x:Class="Ops.Plugins.Tools.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#18202A" />
        <SolidColorBrush x:Key="MutedBrush" Color="#5F6B7A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F6F2EA" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2E6F73" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="MinWidth" Value="92" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="6" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="4" />
        </Style>
    </Application.Resources>
</Application>
